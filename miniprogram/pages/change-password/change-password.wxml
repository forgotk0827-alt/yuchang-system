<view class="page stack">
  <view class="panel stack">
    <view class="title">修改密码</view>
    <view class="field">
      <view class="label">旧密码</view>
      <input password value="{{form.oldPassword}}" data-field="oldPassword" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="label">新密码</view>
      <input password value="{{form.newPassword}}" data-field="newPassword" bindinput="onInput" />
    </view>
    <view class="field">
      <view class="label">确认新密码</view>
      <input password value="{{form.confirmPassword}}" data-field="confirmPassword" bindinput="onInput" />
    </view>
    <button class="btn btn-primary" bindtap="submit">提交修改</button>
  </view>
</view>
