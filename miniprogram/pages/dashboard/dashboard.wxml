<view class="page stack">
  <view class="row">
    <view>
      <view class="title">工作台</view>
      <view class="subtle">{{user.name}} · {{user.role}}{{user.isReviewCommittee ? ' / 评审委员会' : ''}}</view>
    </view>
    <button class="btn btn-primary mini" bindtap="newProposal">新建</button>
  </view>

  <button wx:if="{{canManage}}" class="btn" bindtap="openAdmin">进入管理中心</button>

  <view class="grid-2">
    <view class="panel metric" wx:for="{{cards}}" wx:key="label">
      <view class="metric-label">{{item.label}}</view>
      <view class="metric-value">{{item.value}}</view>
    </view>
  </view>

  <view class="panel stack">
    <view class="row">
      <view class="title small-title">最近提案</view>
      <view class="subtle" bindtap="goProposals">全部</view>
    </view>
    <view wx:if="{{recentProposals.length}}" class="stack">
      <view wx:for="{{recentProposals}}" wx:key="id" class="list-item" bindtap="openProposal" data-id="{{item.id}}">
        <view class="row">
          <view>{{item.title}}</view>
          <view class="status {{item.statusClass}}">{{item.status}}</view>
        </view>
        <view class="subtle">{{item.proposalNo}} · {{item.deptName}} · {{item.estimatedPoints}} 分</view>
      </view>
    </view>
    <view wx:else class="empty">暂无提案</view>
  </view>

  <view class="panel stack">
    <view class="title small-title">站内通知</view>
    <view wx:if="{{notifications.length}}" class="stack">
      <view wx:for="{{notifications}}" wx:key="id" class="list-item">
        <view>{{item.title}}</view>
        <view class="subtle">{{item.content}}</view>
      </view>
    </view>
    <view wx:else class="empty">暂无通知</view>
  </view>
</view>
