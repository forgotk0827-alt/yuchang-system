/* TAKENOW brand blue: PANTONE 286C / CMYK C100 M84 Y24 K0 / RGB 0 51 161 */
page {
  min-height: 100vh;
  background: #f2f6ff;
  color: #17212b;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

.page {
  padding: 28rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #d9e2f5;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 51, 161, 0.08);
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtle {
  color: #61707d;
  font-size: 24rpx;
}

.metric {
  min-height: 140rpx;
}

.metric-label {
  color: #61707d;
  font-size: 24rpx;
}

.metric-value {
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.btn {
  min-height: 88rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #d9e2f5;
  color: #17212b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.btn-primary {
  background: #0033a1;
  color: #ffffff;
  border-color: #0033a1;
}

.btn-danger {
  color: #b42318;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.label {
  font-weight: 700;
  font-size: 26rpx;
}

input,
textarea,
picker {
  min-height: 84rpx;
  background: #ffffff;
  border: 1rpx solid #d9e2f5;
  border-radius: 14rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

textarea {
  min-height: 160rpx;
  padding-top: 18rpx;
}

.status {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef3ff;
  color: #0033a1;
  font-size: 22rpx;
}

.status-warn {
  background: #fff6e3;
  color: #a56b00;
}

.status-danger {
  background: #fff0ee;
  color: #b42318;
}

.list-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.empty {
  color: #61707d;
  text-align: center;
  padding: 48rpx 0;
}
